        </LineString>
      </Placemark>
      <Placemark>
        <name>Burgess Pass Return Route</name>
        <description>Return from camp to Mt. Stephen House via Burgess Pass trail. Views of President Range, Emerald mountains, glaciers, Emerald Lake below.</description>
